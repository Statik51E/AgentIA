rules_version = '2';

// Règles Firestore : chaque utilisateur voit UNIQUEMENT sa propre donnée.
// À copier dans Firebase Console → Firestore → Rules, puis "Publier".
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /{collection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
